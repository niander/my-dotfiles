#!/bin/sh
#
# Copy the current branch name to the clipboard.
#
# Uses whichever clipboard tool is available:
#   - xclip / xsel (Linux X11)
#   - wl-copy     (Linux Wayland)
#   - clip.exe    (WSL / Windows)
#

branch=$(git rev-parse --abbrev-ref HEAD)
echo "$branch"

trimmed=$(printf '%s' "$branch" | tr -d '\n' | tr -d ' ')

if command -v xclip >/dev/null 2>&1; then
  printf '%s' "$trimmed" | xclip -selection clipboard
elif command -v xsel >/dev/null 2>&1; then
  printf '%s' "$trimmed" | xsel --clipboard --input
elif command -v wl-copy >/dev/null 2>&1; then
  printf '%s' "$trimmed" | wl-copy
elif command -v clip.exe >/dev/null 2>&1; then
  printf '%s' "$trimmed" | clip.exe
else
  echo "(no clipboard tool found; install xclip, xsel, wl-clipboard, or use WSL with clip.exe)" >&2
fi
