#!/usr/bin/env bash
#
# Run all dotfiles installers.

set -e

# Default DOTFILES to the dir containing this script's parent if not set.
if [ -z "$DOTFILES" ]; then
  DOTFILES="$(cd "$(dirname "$0")/.." && pwd -P)"
  export DOTFILES
fi

# Require bootstrap to have run first. ~/.zshrc being a symlink is the
# strongest cheap signal that script/bootstrap completed its symlink phase
# (~/.dotfiles is unreliable because the README recommends cloning into it).
# Without this, oh-my-zsh/install.sh's upstream installer can clobber/replace
# ~/.zshrc on a virgin machine.
if [ ! -L "$HOME/.zshrc" ]; then
  echo "script/install: run script/bootstrap first (~/.zshrc is not a symlink)" >&2
  exit 1
fi

pushd "$DOTFILES" > /dev/null

# find the installers and run them iteratively
find . -maxdepth 2 -name install.sh | while read installer ; do bash -c "${installer}" ; done

popd > /dev/null