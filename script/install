#!/usr/bin/env bash
#
# Run all dotfiles installers.

set -e

if [ -z "$DOTFILES" ]; then
  DOTFILES="$(cd "$(dirname "$0")/.." && pwd -P)"
  export DOTFILES
fi

# Require bootstrap to have run first. bootstrap creates ~/.dotfiles as a
# symlink to the actual repo location. Without this guard, oh-my-zsh's
# upstream installer can clobber ~/.zshrc on a virgin machine.
if [ ! -L "$HOME/.dotfiles" ]; then
  echo "script/install: run script/bootstrap first (~/.dotfiles is not a symlink)" >&2
  exit 1
fi

# Also verify the symlink resolves to THIS repo. Otherwise we could be running
# installers from one checkout while the shell is configured to use another.
dotfiles_link="$(cd "$HOME/.dotfiles" 2>/dev/null && pwd -P)"
dotfiles_real="$(cd "$DOTFILES" 2>/dev/null && pwd -P)"
if [ "$dotfiles_link" != "$dotfiles_real" ]; then
  echo "script/install: ~/.dotfiles resolves to '$dotfiles_link', not '$dotfiles_real' (\$DOTFILES=$DOTFILES)." >&2
  echo "  Run script/bootstrap from this checkout, or update the ~/.dotfiles symlink." >&2
  exit 1
fi

pushd "$DOTFILES" > /dev/null

find . -maxdepth 2 -name install.sh -print0 | while IFS= read -r -d '' installer; do
  bash "$installer"
done

popd > /dev/null
