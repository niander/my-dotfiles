#!/usr/bin/env bash
#
# bootstrap installs things.
# CHANGES:
#   - relative path folder script stolen from @scarfacedeb
#    

cd "$(dirname "$0")/.."
DOTFILES_ROOT=$(pwd -P)

set -e

echo ''

info () {
  printf "\r  [ \033[00;34m..\033[0m ] $1\n"
}

user () {
  printf "\r  [ \033[0;33m??\033[0m ] $1\n"
}

success () {
  printf "\r\033[2K  [ \033[00;32mOK\033[0m ] $1\n"
}

fail () {
  printf "\r\033[2K  [\033[0;31mFAIL\033[0m] $1\n"
  echo ''
  exit
}

setup_gitconfig () {
  if ! [ -f git/gitconfig.local.symlink ]
  then
    info 'setup gitconfig'

    # Pick a sensible default credential helper for the current OS.
    git_credential='cache'
    uname_s="$(uname -s)"
    case "$uname_s" in
      Linux*)
        if grep -qi microsoft /proc/version 2>/dev/null; then
          # WSL — reuse the Windows credential manager.
          git_credential='/mnt/c/Program\\ Files/Git/mingw64/bin/git-credential-manager.exe'
        fi
        ;;
      MINGW*|MSYS*|CYGWIN*)
        git_credential='manager'
        ;;
    esac

    user " - What is your git credential provider? [$git_credential]"
    read -r -e -i "$git_credential" git_credential

    user ' - What is your github login?'
    read -e git_login
    user ' - What is your git author name?'
    read -e -i $git_login git_authorname
    user ' - What is your git author email?'
    read -e -i "$git_login@users.noreply.github.com" git_authoremail


    git_credential_escaped=$(printf '%s\n' "$git_credential" | sed 's/[&/\\]/\\&/g')
    sed -e "s/LOGIN/$git_login/g" -e "s/AUTHORNAME/$git_authorname/g" -e "s/AUTHOREMAIL/$git_authoremail/g" -e "s/GIT_CREDENTIAL_HELPER/$git_credential_escaped/g" git/gitconfig.local.symlink.example > git/gitconfig.local.symlink

    success 'gitconfig'
  fi
}


link_file () {
  local src=$1 dst=$2

  local overwrite= backup= skip=
  local action=

  if [ -f "$dst" -o -d "$dst" -o -L "$dst" ]
  then

    if [ "$overwrite_all" == "false" ] && [ "$backup_all" == "false" ] && [ "$skip_all" == "false" ]
    then

      local currentSrc="$(readlink $dst)"

      if [ "$currentSrc" == "$src" ]
      then

        skip=true;

      else

        user "File already exists: $dst ($(basename "$src")), what do you want to do?\n\
        [s]kip, [S]kip all, [o]verwrite, [O]verwrite all, [b]ackup, [B]ackup all?"
        read -n 1 action

        case "$action" in
          o )
            overwrite=true;;
          O )
            overwrite_all=true;;
          b )
            backup=true;;
          B )
            backup_all=true;;
          s )
            skip=true;;
          S )
            skip_all=true;;
          * )
            ;;
        esac

      fi

    fi

    overwrite=${overwrite:-$overwrite_all}
    backup=${backup:-$backup_all}
    skip=${skip:-$skip_all}

    if [ "$overwrite" == "true" ]
    then
      rm -rf "$dst"
      success "removed $dst"
    fi

    if [ "$backup" == "true" ]
    then
      mv "$dst" "${dst}.backup"
      success "moved $dst to ${dst}.backup"
    fi

    if [ "$skip" == "true" ]
    then
      success "skipped $src"
    fi
  fi

  if [ "$skip" != "true" ]  # "false" or empty
  then
    ln -s "$1" "$2"
    success "linked $1 to $2"
  fi
}

install_dotfiles () {
  info 'installing dotfiles'

  local overwrite_all=false backup_all=false skip_all=false

  for src in $(find -H "$DOTFILES_ROOT" -mindepth 1 -name '.*' -type d -prune -o -name '*.symlink' -print)
  do
    relative_src=$(echo $src | sed -e "s=$DOTFILES_ROOT==" -e "s=.symlink==")
    dst="$HOME/.$(echo $relative_src | cut -d "/" -f3-)"

    # create directory if needed
    dir=$(dirname $dst)
    if ! [ -d $dir ]
    then
      mkdir -p $dir
    fi
    #dst="$HOME/.$(basename "${src%.*}")"
    link_file "$src" "$dst"
  done
}

setup_gitconfig
install_dotfiles

# Add ~/.dotfiles link if not yet
if ! [[ -a "$HOME/.dotfiles" ]]
then
  echo ''
  echo "  Creating symbolic link ~/.dotfiles to $DOTFILES_ROOT"
  ln -s "$DOTFILES_ROOT" "$HOME/.dotfiles"
fi

# Verify ~/.dotfiles is now the expected symlink. If the user cloned directly
# into ~/.dotfiles (against README guidance), the directory exists but is not
# a symlink, and script/install's guard will (correctly) refuse to run.
# Fail here with a clearer message than install's guard would give.
if [ ! -L "$HOME/.dotfiles" ]; then
  fail "~/.dotfiles exists but is not a symlink (cloned directly into ~/.dotfiles?). Move the clone to another path (e.g. ~/code/dotfiles) and rerun script/bootstrap."
fi

# Run topical install scripts.
info 'running script/install'
DOTFILES="$DOTFILES_ROOT" "$DOTFILES_ROOT/script/install"

echo ''
echo '  All installed!'